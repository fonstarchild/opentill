{
  "productName": "Opentill",
  "version": "0.1.0",
  "identifier": "dev.opentill.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/opentill-backend"
    ],
    "resources": {
      "backend/opentill.db.example": "opentill.db.example"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Opentill",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:47821 https://api.stripe.com; script-src 'self'"
    }
  }
}
